rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuario solo puede leer y escribir su propio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sesiones de palabras: cualquiera puede leer; solo autenticados pueden crear/modificar
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;

      match /words/{wordId} {
        allow read: if true;
        allow write: if true; // invitados sin cuenta también pueden añadir palabras
      }
    }
  }
}
